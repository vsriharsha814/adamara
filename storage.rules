rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Public form uploads: anyone can create under requests/{requestId}/ (max 10MB per file)
    match /requests/{requestId}/{fileName} {
      allow create: if request.resource.size < 10 * 1024 * 1024;
      allow read: if request.auth != null;
      allow delete: if request.auth != null;
    }
  }
}
