rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper: true if the current user is an allowed admin
    function isAllowedAdmin() {
      return request.auth != null
        && exists(/databases/$(database)/documents/allowed_admins/$(request.auth.uid));
    }

    // Ad requests: anyone can create (public form); only allowed admins can read/update/delete
    match /requests/{requestId} {
      allow create: if true;
      allow read, update, delete: if isAllowedAdmin();
    }

    // Helper: true if login_requests doc for uid has makeAdmin == true
    function loginRequestMakeAdmin(uid) {
      return exists(/databases/$(database)/documents/login_requests/$(uid))
        && get(/databases/$(database)/documents/login_requests/$(uid)).data.get('makeAdmin', false) == true;
    }

    // Allowed admins: user can read own; existing admins can create for others; user can create own if login_requests has makeAdmin true.
    match /allowed_admins/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow create: if request.auth != null && (
        (request.auth.uid != uid && isAllowedAdmin())
        || (request.auth.uid == uid && loginRequestMakeAdmin(uid))
      );
      allow update, delete: if request.auth != null
        && request.auth.uid != uid
        && isAllowedAdmin();
    }

    // Login requests: requester can create/update/read own; admins can read, update (e.g. set makeAdmin), and delete.
    match /login_requests/{requestId} {
      allow create: if request.auth != null && request.auth.uid == requestId;
      allow update, read: if request.auth != null && (request.auth.uid == requestId || isAllowedAdmin());
      allow delete: if isAllowedAdmin();
    }

    // Users: each user can read/write their own doc (e.g. when granted admin); admins can read all.
    match /users/{uid} {
      allow read: if request.auth != null && (request.auth.uid == uid || isAllowedAdmin());
      allow create, update: if request.auth != null && request.auth.uid == uid;
      allow delete: if isAllowedAdmin();
    }
  }
}
