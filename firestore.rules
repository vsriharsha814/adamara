rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Ad requests: anyone can create (public form); only signed-in users can read/update/delete (admin)
    match /requests/{requestId} {
      allow create: if true;
      allow read, update, delete: if request.auth != null;
    }
    // Optional: admin allowlist; uncomment and maintain document IDs = Firebase UIDs if you want to restrict admin
    // match /admins/{uid} {
    //   allow read: if request.auth != null && request.auth.uid == uid;
    // }
  }
}
