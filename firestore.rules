rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper: true if the current user is an allowed admin
    function isAllowedAdmin() {
      return request.auth != null
        && exists(/databases/$(database)/documents/allowed_admins/$(request.auth.uid));
    }

    // Ad requests: anyone can create (public form); only allowed admins can read/update/delete
    match /requests/{requestId} {
      allow create: if true;
      allow read, update, delete: if isAllowedAdmin();
    }

    // Allowed admins: doc id = Firebase UID. Only that user can read their own; only existing admins can create (for new admins).
    // First admin must be created manually in Firebase Console (allowed_admins/<uid> with field email or empty).
    match /allowed_admins/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow create: if request.auth != null
        && request.auth.uid != uid
        && isAllowedAdmin();
      allow update, delete: if request.auth != null
        && request.auth.uid != uid
        && isAllowedAdmin();
    }

    // Login requests: unapproved users submit here. Requester can create/update/read own doc; admins can read all and delete.
    match /login_requests/{requestId} {
      allow create, update: if request.auth != null && request.auth.uid == requestId;
      allow read: if isAllowedAdmin() || (request.auth != null && request.auth.uid == requestId);
      allow delete: if isAllowedAdmin();
    }
  }
}
